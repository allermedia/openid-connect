{
  "name": "@aller/openid-connect",
  "version": "0.0.1",
  "description": "Express middleware to protect web applications using OpenID Connect.",
  "author": {
    "name": "Aller Media",
    "url": "https://github.com/allermedia"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/allermedia/pino-gcp-transport.git"
  },
  "homepage": "https://github.com/auth0/express-openid-connect",
  "license": "MIT",
  "type": "module",
  "main": "index.js",
  "files": [
    "lib",
    "middleware",
    "index.d.ts"
  ],
  "scripts": {
    "lint": "eslint . --cache && prettier . -c",
    "start:example": "node ./examples/run_example.js",
    "test": "mocha --max-http-header-size=16384",
    "posttest": "npm run lint",
    "cov:html": "c8 -n src -r html -r text mocha",
    "test:lcov": "c8 -n src -r lcov -r text mocha",
    "test:types": "tsd .",
    "docs": "typedoc --options typedoc.js index.d.ts"
  },
  "dependencies": {
    "cookie": "^1.1.1",
    "debug": "^4.4.1",
    "joi": "^18.0.2",
    "jose": "^6.1.3",
    "on-headers": "^1.1.0",
    "openid-client": "^6.8.1"
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/node": "^22.19.10",
    "c8": "10.1.3",
    "chai": "^6.2.2",
    "chai-as-promised": "^8.0.2",
    "connect-redis": "^5.2.0",
    "dotenv": "^8.6.0",
    "eslint": "^9.31.0",
    "eslint-plugin-import": "^2.32.0",
    "express": "^5.2.1",
    "express-oauth2-jwt-bearer": "^1.6.1",
    "memorystore": "^1.6.7",
    "mocha": "^11.7.5",
    "nock": "^14.0.10",
    "prettier": "^3.6.2",
    "redis-mock": "^0.56.3",
    "sinon": "^21.0.1",
    "supertest": "7.2.2",
    "tsd": "^0.33.0",
    "typescript": "^5.8.3",
    "undici": "^7.21.0"
  },
  "peerDependencies": {
    "express": ">= 4.17.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
