{
  "name": "@aller/openid-connect",
  "version": "0.0.4",
  "description": "Express middleware to protect web applications using OpenID Connect.",
  "type": "module",
  "main": "./lib/index.cjs",
  "module": "./src/index.js",
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./src/index.js",
      "require": "./lib/index.cjs"
    }
  },
  "author": {
    "name": "Aller Media",
    "url": "https://github.com/allermedia"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/allermedia/openid-connect.git"
  },
  "homepage": "https://github.com/allermedia/openid-connect",
  "license": "MIT",
  "files": [
    "src",
    "lib",
    "types/index.d.ts",
    "types/index.d.ts.map"
  ],
  "scripts": {
    "test": "mocha --max-http-header-size=16384",
    "posttest": "npm run lint && npm run build",
    "lint": "eslint . --cache && prettier . -c && npm run test:md",
    "test:md": "texample",
    "cov:html": "c8 -n src -r html -r text mocha",
    "test:lcov": "c8 -n src -r lcov -r text mocha",
    "build": "rollup -c && dts-buddy"
  },
  "dependencies": {
    "cookie": "^1.1.1",
    "debug": "^4.4.1",
    "joi": "^18.0.2",
    "on-headers": "^1.1.0",
    "openid-client": "^6.8.1"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@types/debug": "^4.1.12",
    "@types/express": "5.0.6",
    "@types/node": "^22.19.10",
    "@types/on-headers": "^1.0.4",
    "c8": "^11.0.0",
    "chai": "^6.2.2",
    "dts-buddy": "^0.7.0",
    "eslint": "^9.31.0",
    "eslint-plugin-import": "^2.32.0",
    "express": "^5.2.1",
    "jose-v2": "npm:jose@^2.0.7",
    "mocha": "^11.7.5",
    "mocha-cakes-2": "^3.3.0",
    "nock": "^14.0.10",
    "prettier": "^3.6.2",
    "rollup": "^4.59.0",
    "supertest": "7.2.2",
    "texample": "^0.1.0",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "express": ">= 4.17.0",
    "jose": "6.x"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
